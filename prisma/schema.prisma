generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  role      String     @default("agent")
  leads     Lead[]
  auditLogs AuditLog[]

  @@map("users")
}

model DM {
  id           String         @id @default(uuid())
  platform     String
  senderName   String
  senderHandle String
  message      String
  timestamp    DateTime
  status       String         @default("new")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  drafts       Draft[]
  leads        Lead[]
  notifications Notification[]

  @@map("dms")
}

model Draft {
  id              String   @id @default(uuid())
  dmId            String
  content         String
  confidenceScore Float    @default(0)
  isEdited        Boolean  @default(false)
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  dm              DM       @relation(fields: [dmId], references: [id], onDelete: Cascade)

  @@map("drafts")
}

model Lead {
  id            String         @id @default(uuid())
  dmId          String
  name          String
  contact       String?
  budget        String?
  location      String?
  intent        String?
  score         Float          @default(0)
  priorityFlag  Boolean        @default(false)
  salesforceId  String?
  status        String         @default("new")
  assignedTo    String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  dm            DM             @relation(fields: [dmId], references: [id], onDelete: Cascade)
  assignedUser  User?          @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  notifications Notification[]

  @@map("leads")
}

model Notification {
  id        String   @id @default(uuid())
  leadId    String?
  dmId      String?
  type      String
  status    String   @default("unread")
  recipient String
  details   String?
  createdAt DateTime @default(now())
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  dm        DM?      @relation(fields: [dmId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String
  userId     String?
  details    String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}